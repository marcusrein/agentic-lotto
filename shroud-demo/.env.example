# Shroud TEE proxy URL (1Claw Intents API + LLM proxy)
ONECLAW_SHROUD_URL=https://shroud.1claw.xyz

# 1Claw Vault API (for agent token exchange)
ONECLAW_API_URL=https://api.1claw.xyz

# Your user API key — needed once to run "npm run setup" (creates agent and writes agent vars below).
# Get it at https://1claw.xyz/settings/api-keys
ONECLAW_API_KEY=ocv_your_key_here

# Agent credentials — filled by "npm run setup" or paste from dashboard after creating an agent.
ONECLAW_AGENT_ID=your-agent-uuid
ONECLAW_AGENT_API_KEY=ocv_your_agent_api_key

# Optional: OpenAI API key for LLM proxy test. If not set, Shroud will try to
# fetch the key from your vault at providers/openai/api-key (agent must have read access).
# OPENAI_API_KEY=sk-...

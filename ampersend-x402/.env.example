# ── 1Claw Credentials ─────────────────────────────────────────────────
ONECLAW_API_KEY=ocv_your_agent_key_here
ONECLAW_VAULT_ID=your-vault-uuid
ONECLAW_AGENT_ID=your-agent-uuid
# ONECLAW_BASE_URL=https://api.1claw.xyz

# ── Ampersend Smart Account ──────────────────────────────────────────
SMART_ACCOUNT_ADDRESS=0x_your_smart_account_address

# Ampersend API URL (optional; defaults to production)
# AMPERSEND_API_URL=https://api.ampersend.ai

# Base RPC URL (optional; used for client USDC balance + server facilitator verify/settle)
# BASE_RPC_URL=https://mainnet.base.org

# ── Session / Buyer Key ──────────────────────────────────────────────
#
# Option A: provide the session key directly.
# BUYER_PRIVATE_KEY=0x...
#
# Option B (default): leave BUYER_PRIVATE_KEY unset. The demo fetches
# the key from your 1Claw vault at the path below.
# BUYER_KEY_PATH=keys/x402-session-key
# BUYER_KEY_PATH=keys/buyer-private-key

# ── Paywall Server (local facilitator) ───────────────────────────────
#
# The server runs a LOCAL x402 facilitator that settles payments
# on-chain. It supports smart-account (ERC-6492) signatures natively.
#
# X402_FACILITATOR_KEY — private key of an EOA with Base ETH for gas.
#   Only ~$0.01 of ETH needed. If unset, the server fetches the same
#   session key from the 1Claw vault (BUYER_KEY_PATH).
# X402_FACILITATOR_KEY=0x...
#   Without ETH on the facilitator EOA, settlement fails with
#   "invalid_exact_evm_transaction_failed" and an empty transaction hash.
#
# X402_PAY_TO_ADDRESS — wallet that receives USDC payments.
X402_PAY_TO_ADDRESS=0x_your_receiving_address
# X402_SERVER_PORT=4021

# ── One-time Setup ───────────────────────────────────────────────────
# Run: npm run setup
# Uses a HUMAN API key (1ck_...), not the agent key.
# ONECLAW_FULL_API_KEY=1ck_your_user_key_here
# X402_SESSION_KEY=0x...

# ── Debug ────────────────────────────────────────────────────────────
# X402_CLIENT_DEBUG=1

# Shroud base URL (LLM + Intents)
ONECLAW_SHROUD_URL=https://shroud.1claw.xyz

# Vault API (agent token exchange)
ONECLAW_API_URL=https://api.1claw.xyz

# User API key — required for `npm run setup` (creates agent with Shroud enabled).
# Get it at https://1claw.xyz/settings/api-keys
ONECLAW_API_KEY=1ck_your_user_api_key_here

# Agent credentials — filled by `npm run setup` or paste from dashboard.
# Use an org where Settings → Billing → LLM Token Billing is Active (Stripe checkout completed).
ONECLAW_AGENT_ID=your-agent-uuid
ONECLAW_AGENT_API_KEY=ocv_your_agent_api_key

# Optional: OpenAI key for the LLM call. If unset, Shroud loads providers/openai/api-key from the vault.
# OPENAI_API_KEY=sk-...
